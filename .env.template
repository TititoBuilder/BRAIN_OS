# Anthropic Admin API key for usage monitoring and budget enforcement (03_APIS scripts)
ANTHROPIC_ADMIN_KEY=sk-ant-admin-your-key-here

# Daily Anthropic API spend limit in USD — budget monitor alerts when exceeded
DAILY_BUDGET_USD=5.00

# Monthly Anthropic API spend limit in USD — budget monitor alerts when exceeded
MONTHLY_BUDGET_USD=20.00

# Telegram bot token (from BotFather) for budget alert notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram chat/channel ID that receives budget alert messages
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
